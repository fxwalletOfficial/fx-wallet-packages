+#[cfg(feature = "rest")]
 mod rest;
+#[cfg(feature = "rest")]
 pub use rest::RestQuery;
 
 /// Make the REST error type available public as it can be used for any API endpoint.
+#[cfg(feature = "rest")]
 pub use rest::RestError;
 
