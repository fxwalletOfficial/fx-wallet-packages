# Split-feature patch for snarkvm-ledger-query 4.5.0 (Apache-2.0).
#
# Moves the ureq-backed REST query out of the `query` feature into a new
# opt-in `rest` feature, so the default `query` build (which only uses
# StaticQuery) links no HTTP stack. Apply on top of a verbatim crates.io
# 4.5.0 extraction. See rust/vendor/README.md.
#
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -50,6 +50,14 @@
     "dep:snarkvm-ledger-block",
     "dep:snarkvm-ledger-store",
     "dep:snarkvm-synthesizer-program",
+]
+# Local split-feature patch (fx-wallet, Apache-2.0): the `ureq`-backed REST query
+# is moved out of `query` into this opt-in `rest` feature, so the default build —
+# which only ever uses `StaticQuery` — links no HTTP stack. `rest` implies `query`
+# (RestQuery needs the block/store/program types `query` brings). See
+# `rust/vendor/README.md` and `rust/vendor/ledger-query-split-rest.patch`.
+rest = [
+    "query",
     "dep:ureq",
 ]
 serial = [
