[package]
name = "snarkvm-synthesizer"
version = "4.5.0"
authors = [ "The Aleo Team <hello@aleo.org>" ]
description = "Synthesizer for a decentralized virtual machine"
homepage = "https://aleo.org"
repository = "https://github.com/ProvableHQ/snarkVM"
keywords = [
  "aleo",
  "cryptography",
  "blockchain",
  "decentralized",
  "zero-knowledge"
]
categories = [
  "compilers",
  "cryptography",
  "mathematics",
  "wasm",
  "web-programming"
]
include = [ "Cargo.toml", "src", "README.md", "LICENSE.md" ]
license = "Apache-2.0"
edition = "2024"

[features]
locktick = [
  "dep:locktick",
  "snarkvm-ledger-puzzle/locktick",
  "snarkvm-ledger-puzzle-epoch/locktick",
  "snarkvm-ledger-store/locktick",
  "snarkvm-synthesizer-process/locktick"
]
async = [ "snarkvm-ledger-query/async", "snarkvm-synthesizer-process/async" ]
cuda = [ "snarkvm-algorithms/cuda" ]
history = [ "serde" ]
rocks = [ "snarkvm-ledger-store/rocks" ]
serial = [
  "snarkvm-console/serial",
  "snarkvm-ledger-block/serial",
  "snarkvm-ledger-committee/serial",
  "snarkvm-ledger-query/serial",
  "snarkvm-ledger-store/serial",
  "snarkvm-synthesizer-process/serial",
  "snarkvm-synthesizer-program/serial",
  "snarkvm-synthesizer-snark/serial"
]
setup = [ ]
test = [ "snarkvm-console/test", "snarkvm-synthesizer-process/test" ]
timer = [ "aleo-std/timer" ]
wasm = [
  "snarkvm-console/wasm",
  "snarkvm-ledger-block/wasm",
  "snarkvm-ledger-committee/wasm",
  "snarkvm-ledger-query/wasm",
  "snarkvm-ledger-store/wasm",
  "snarkvm-synthesizer-process/wasm",
  "snarkvm-synthesizer-program/wasm",
  "snarkvm-synthesizer-snark/wasm"
]
dev-print = [ "snarkvm-utilities/dev-print" ]
dev_skip_checks = [ "snarkvm-synthesizer-process/dev_skip_checks" ]
test_consensus_heights = [ "snarkvm-synthesizer-process/test_consensus_heights" ]

[[bench]]
name = "kary_merkle_tree"
path = "benches/kary_merkle_tree.rs"
harness = false

[dependencies.snarkvm-algorithms]
workspace = true

[dependencies.snarkvm-circuit]
workspace = true

[dependencies.snarkvm-console]
workspace = true

[dependencies.snarkvm-ledger-block]
workspace = true

[dependencies.snarkvm-ledger-committee]
workspace = true

[dependencies.snarkvm-ledger-narwhal-data]
workspace = true

[dependencies.snarkvm-ledger-puzzle]
workspace = true

[dependencies.snarkvm-ledger-puzzle-epoch]
workspace = true
features = [ "synthesis" ]

[dependencies.snarkvm-ledger-query]
workspace = true
features = [ "query" ]

[dependencies.snarkvm-ledger-store]
workspace = true

[dependencies.snarkvm-synthesizer-process]
workspace = true

[dependencies.snarkvm-synthesizer-program]
workspace = true

[dependencies.snarkvm-synthesizer-snark]
workspace = true

[dependencies.snarkvm-utilities]
workspace = true

[dependencies.aleo-std]
workspace = true

[dependencies.anyhow]
workspace = true

[dependencies.indexmap]
workspace = true
features = [ "serde", "rayon" ]

[dependencies.itertools]
workspace = true

[dependencies.locktick]
workspace = true
features = [ "parking_lot" ]
optional = true

[dependencies.lru]
workspace = true

[dependencies.parking_lot]
workspace = true

[dependencies.rand]
workspace = true

[dependencies.rayon]
workspace = true

[dependencies.serde]
workspace = true
optional = true

[dependencies.serde_json]
workspace = true
features = [ "preserve_order" ]

[dependencies.tokio]
version = "1"
features = [ "sync" ]

[dependencies.tracing]
workspace = true

[dev-dependencies.anyhow]
workspace = true

[dev-dependencies.bincode]
workspace = true

[dev-dependencies.criterion]
workspace = true

[dev-dependencies.hex]
workspace = true

[dev-dependencies.k256]
version = "0.13"
features = [ "digest", "ecdsa" ]
default-features = false

[dev-dependencies.snarkvm-console]
workspace = true
features = [ "filesystem" ]

[dev-dependencies.snarkvm-ledger-committee]
workspace = true
features = [ "test-helpers" ]

[dev-dependencies.snarkvm-ledger-narwhal-batch-header]
workspace = true
features = [ "test-helpers" ]

[dev-dependencies.snarkvm-synthesizer-process]
workspace = true
features = [ "test" ]

[dev-dependencies.snarkvm-ledger-test-helpers]
path = "../ledger/test-helpers"

[dev-dependencies.rayon]
workspace = true

[dev-dependencies.serde_yaml]
version = "0.9"

[dev-dependencies.tempfile]
workspace = true

[dev-dependencies.walkdir]
version = "2"
