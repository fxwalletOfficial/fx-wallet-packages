# Param-dir patch for snarkvm-parameters 4.5.0 (Apache-2.0).
#
# Adds process-global control over the directory proving parameters load
# from / download into, so the Dart layer can point reads at the mobile app
# sandbox (upstream hard-wires aleo_std::aleo_dir() = ~/.aleo, with no env
# override). The size+checksum guards in the load macro are UNCHANGED, so the
# trust boundary stays in Rust. The 'choose dir' and 'begin load' transitions
# share one mutex (see src/parameter_dir.rs) so they cannot interleave. The
# curl download path is untouched here; it is removed in workstream A (PR3).
# Apply on top of a verbatim 4.5.0 extraction.
#
# New file: src/parameter_dir.rs (the param-dir state machine, Contract 2).
#
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -31,6 +31,14 @@
 pub mod errors;
 pub use errors::*;
 
+// fx-wallet param-dir patch (NOT upstream): process-global override of the
+// directory parameters load from, used by the load macro below. See
+// `rust/vendor/parameters-param-dir.patch`.
+mod parameter_dir;
+pub use parameter_dir::{
+    effective_parameter_dir, parameter_dir_for_load, set_parameter_dir, ParamDirError,
+};
+
 pub mod canary;
 
 pub mod mainnet;
--- a/src/macros.rs
+++ b/src/macros.rs
@@ -172,8 +172,12 @@
     ($remote_urls: expr, $local_dir: expr, $filename: expr, $metadata: expr, $expected_checksum: expr, $expected_size: expr) => {
         cfg_if::cfg_if! {
             if #[cfg(all(feature = "filesystem", not(feature="wasm")))] {
-                // Compose the correct file path for the parameter file.
-                let mut file_path = aleo_std::aleo_dir();
+                // fx-wallet param-dir patch (NOT upstream): atomically freeze the
+                // parameter directory on first read and read it, from the
+                // (overridable) effective dir instead of the hard-wired
+                // `aleo_std::aleo_dir()`. One lock guards "freeze + read" and
+                // `set_parameter_dir`, so they cannot interleave.
+                let mut file_path = $crate::parameter_dir_for_load();
                 file_path.push($local_dir);
                 file_path.push($filename);
 
